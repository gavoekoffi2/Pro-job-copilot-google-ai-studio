# --- Provider IA (côté serveur Netlify uniquement, jamais exposé au navigateur) ---
# Recommandé : OpenRouter (gère le texte, les images ET les PDF pour l'import de CV).
OPENROUTER_API_KEY=sk-or-v1-votre_cle_ici
OPENROUTER_MODEL=google/gemini-2.5-flash

# Budget de sortie. À augmenter si des CV très longs sont tronqués.
# OPENROUTER_MAX_TOKENS=8192

# --- Alternative texte seul (pas d'import PDF/image) ---
# Si NVIDIA_API_KEY est défini, le provider NVIDIA est utilisé par défaut.
# Forcez le provider avec AI_PROVIDER=openrouter | nvidia
# AI_PROVIDER=openrouter
# NVIDIA_API_KEY=
# NVIDIA_MODEL=meta/llama-3.1-405b-instruct
