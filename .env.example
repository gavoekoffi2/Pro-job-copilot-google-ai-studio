# --- Provider IA : OpenRouter (côté serveur Netlify/Hostinger Node uniquement, jamais exposé au navigateur) ---
# Une seule clé OpenRouter, mais le bon modèle est choisi selon la tâche :
#   - Analyse de CV (score ATS, forces/faiblesses)      -> Gemini  (rapide, bon analyste)
#   - Génération de texte (rédaction, traduction,        -> Claude  (meilleure qualité rédactionnelle)
#     adaptation, optimisation, import/extraction)
OPENROUTER_API_KEY=sk-or-..._ici

# --- Paiement GeniusPay ---
# Sandbox : pk_sandbox_... / secret sandbox
# Live : pk_live_... / secret live
GENIUSPAY_API_KEY=pk_live_..._ici
GENIUSPAY_API_SECRET=secret_live_..._ici
PUBLIC_SITE_URL=https://votre-domaine-jobtask-ai.com

# --- Compte super administrateur (OBLIGATOIRE pour l'espace admin) ---
# Aucun identifiant par défaut n'existe dans le code : sans ces deux variables,
# aucun compte super admin ne peut être créé automatiquement.
# Le mot de passe doit contenir au moins 8 caractères (choisissez-en un fort et unique).
JOBTASK_SUPER_ADMIN_EMAIL=admin@votre-domaine.com
JOBTASK_SUPER_ADMIN_PASSWORD=changez-ce-mot-de-passe-fort

# --- Anti-abus endpoint IA ---
# Nombre max de requêtes IA par minute et par adresse IP (défaut : 12).
# AI_RATE_LIMIT_PER_MINUTE=12

# Modèle utilisé pour l'ANALYSE (Gemini par défaut).
OPENROUTER_MODEL_ANALYZE=google/gemini-2.5-flash
# Modèle utilisé pour la GÉNÉRATION de texte (Claude par défaut).
OPENROUTER_MODEL_GENERATE=anthropic/claude-3.7-sonnet

# Budget de sortie. À augmenter si des CV très longs sont tronqués.
# OPENROUTER_MAX_TOKENS=8192

# Moteurs d'extraction des PDF (dans l'ordre, séparés par des virgules).
# Par défaut on tente l'extraction de texte (gratuite, idéale pour un PDF numérique)
# puis l'OCR (mistral-ocr) si le PDF est SCANNÉ / composé d'images -> texte vide.
# OPENROUTER_PDF_ENGINES=pdf-text,mistral-ocr
